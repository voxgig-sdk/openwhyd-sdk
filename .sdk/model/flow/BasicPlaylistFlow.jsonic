# BasicPlaylistFlow

main: kit: flow: BasicPlaylistFlow:
{
  entity: "playlist",
  kind: "basic",
  name: "BasicPlaylistFlow",
  step: [
    {
      match: {
        username: "username01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "playlist_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicPlaylistFlow"
}